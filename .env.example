# GridSight environment variables.
#
# The deployed app needs NO keys — it serves a committed static snapshot, so a
# shared demo makes zero live API calls (nothing to run up a bill or exploit).
#
# Keys below are used ONLY by the build-time ingestion pipeline (`npm run ingest`)
# and the brief generator (`npm run briefs`). Put them in .env.local (gitignored).

# Enables real Claude-generated per-site rationale briefs at build time.
# Results are cached to data/briefs.snapshot.json and served statically.
# Without it, briefs fall back to deterministic templated text.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

# Optional: only if you switch the base map to Mapbox tiles. The default map
# uses MapLibre + a free demo raster style and needs NO token.
NEXT_PUBLIC_MAPBOX_TOKEN=
